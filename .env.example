# Example environment variables for LobeChat deployment
# Copy this file to .env and fill in your values

# Auth
AUTH_ALLOWED_EMAILS=your@email.com
# AUTH_DISABLE_EMAIL_PASSWORD=1

# ===========================
# ====== Preset config ======
# ===========================
LOBE_PORT=3210
RUSTFS_PORT=9000
RUSTFS_ADMIN_PORT=9001
APP_URL=http://lobe.local
INTERNAL_APP_URL=http://lobe:3210

# Secrets (generate with: openssl rand -base64 32)
KEY_VAULTS_SECRET=your-key-vaults-secret
AUTH_SECRET=your-auth-secret

# Postgres
LOBE_DB_NAME=lobechat
POSTGRES_PASSWORD=your-postgres-password

# RustFS S3 configuration
S3_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=your-access-key
RUSTFS_SECRET_KEY=your-secret-key
RUSTFS_LOBE_BUCKET=lobe

# JWKS Key (generate with: npx jose generate-key RS256 --use sig)
JWKS_KEY=

# AI Provider API Keys (add as needed)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_PROXY_URL=
